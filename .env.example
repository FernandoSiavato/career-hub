# career-hub environment variables
# Copy this file to .env and fill in your values. Never commit .env.

# Where career-hub stores YOUR career data (profiles, CVs, applications, etc.)
# Default if unset: ~/.career-hub/
JOBSEARCH_DATA_DIR=

# Apify API token (optional). Required only if you want the dynamic job scanner
# to query LinkedIn / Indeed / ReliefWeb / Devex / Workable via Apify actors.
# Free ATS scraping (Greenhouse, Ashby, Lever) does not need this.
# Get a token at https://apify.com
APIFY_TOKEN=

# Google API key (optional). Required only if you use AI image generation
# from the /apply or /ads-generate skills. Get one at https://aistudio.google.com
GOOGLE_API_KEY=
