# career-hub data-directory env vars
# Copy this file to ``.env`` (in this same directory) and fill in your secrets.
# Never commit .env.

# Apify token (only needed if you enable Apify actors in portals.yml)
# Get one at https://apify.com
APIFY_TOKEN=

# Google API key (only needed if you use AI image generation in extra skills)
GOOGLE_API_KEY=
